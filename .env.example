# ============================================================
# ZeroGate — Environment Variables
# Copy this file to .env and fill every value before deploying
# NEVER commit .env to version control
# ============================================================

# ---- AWS --------------------------------------------------
AWS_REGION=eu-west-1
AWS_INSTANCE_TYPE=t2.micro
# Used by Terraform — set via `aws configure` or export
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ---- Domain -----------------------------------------------
DOMAIN=yourdomain.com
PORTAL_SUBDOMAIN=portal
AUTH_SUBDOMAIN=auth
ACCESS_SUBDOMAIN=access
MONITORING_SUBDOMAIN=monitor

# Full URLs (derived from above — set explicitly if different)
AUTHENTIK_URL=https://auth.yourdomain.com
GUACAMOLE_URL=https://access.yourdomain.com
GRAFANA_URL=https://monitor.yourdomain.com

# ---- Cloudflare -------------------------------------------
CF_TUNNEL_TOKEN=           # From: cloudflared tunnel token <tunnel-name>
CF_ACCOUNT_ID=             # From: Cloudflare dashboard → Overview

# ---- Authentik --------------------------------------------
# Generate: openssl rand -hex 32
AUTHENTIK_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# PostgreSQL for Authentik
# Generate: openssl rand -hex 24
AUTHENTIK_DB_PASSWORD=CHANGE_ME_openssl_rand_hex_24
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_NAME=authentik

# Redis for Authentik
# Generate: openssl rand -hex 24
AUTHENTIK_REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_24

# Authentik initial admin (only used on first setup)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@yourdomain.com
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_strong_password_here

# ---- Guacamole --------------------------------------------
# Generate: openssl rand -hex 24
GUACAMOLE_DB_PASSWORD=CHANGE_ME_openssl_rand_hex_24
GUACAMOLE_DB_USER=guacamole
GUACAMOLE_DB_NAME=guacamole_db

# Guacamole OIDC (from Authentik application)
GUACAMOLE_OIDC_CLIENT_ID=guacamole
GUACAMOLE_OIDC_CLIENT_SECRET=CHANGE_ME_from_authentik_application

# ---- Grafana ----------------------------------------------
# Strong password — min 12 chars
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
GRAFANA_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32

# Grafana OIDC via Authentik (create application in Authentik admin)
GRAFANA_OIDC_CLIENT_SECRET=CHANGE_ME_from_authentik_application

# ---- Alerting ---------------------------------------------
ALERT_EMAIL=security@yourdomain.com
SMTP_ENABLED=false
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
SMTP_FROM=ZeroGate Alerts <alerts@yourdomain.com>

# ---- Backup -----------------------------------------------
BACKUP_S3_BUCKET=zerogate-backups-ACCOUNT_ID
BACKUP_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ---- Postgres shared settings (used by both DBs) ----------
POSTGRES_VERSION=16-alpine

# ============================================================
# v1.2 — SCIM + SAML + Business Hours + Session Recording
# ============================================================

# ---- SCIM provisioning (inbound from HR system) -----------
# Token is generated in Authentik Admin → Directory → Tokens
# Provide it to your HR system as a Bearer token.
# SCIM endpoint: https://auth.yourdomain.com/source/scim/hr-scim/v2/
# (no env var needed — configured entirely in Authentik)

# ---- SAML 2.0 federation ----------------------------------
# Filled in docker/authentik/blueprints/zerogate-saml.yaml:
#   sso_url, slo_url, issuer, sp_binding
# Export SP metadata from:
#   https://auth.yourdomain.com/source/saml/enterprise-idp/metadata/
# (no env var needed — configured in blueprint + Authentik UI)

# ---- Business hours (time-based access policy) -----------
# Defaults are set in zerogate-flows.yaml (Europe/Lisbon, 08:00-18:00)
# Override per-deployment by editing the ExpressionPolicy in Authentik.
# Add on-call users to the 'business-hours-exempt' group to bypass.

# ---- Session recording ------------------------------------
# Recordings stored in Docker volume: zerogate-guacamole-recordings
# Enable on all connections: make recording-enable
# List recordings: make recording-list
# Archive to S3: make recording-archive
RECORDING_RETENTION_DAYS=90    # delete local recordings older than this

# ============================================================
# v1.1 — Geo-blocking + Threat Response
# ============================================================

# Cloudflare API token (Zone:Firewall Services:Edit permission)
# Get from: Cloudflare dashboard → My Profile → API Tokens
# Also needed by Terraform for cloudflare.tf resources
CF_API_TOKEN=

# Cloudflare zone ID (from: dashboard → your domain → Overview)
CF_ZONE_ID=

# Threat response tuning
# Bans an IP after this many auth failures within WINDOW
THREAT_BAN_THRESHOLD=10
# Lookback window in minutes when counting failures
THREAT_WINDOW_MINUTES=10
