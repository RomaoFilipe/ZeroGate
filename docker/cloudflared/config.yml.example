# ============================================================
# Cloudflare Tunnel configuration
# Copy to config.yml and fill YOUR_TUNNEL_ID + YOUR_DOMAIN
# This file is gitignored — it contains the tunnel ID.
# ============================================================

tunnel: YOUR_TUNNEL_ID
credentials-file: /etc/cloudflared/credentials.json

# Tunnel-level settings
loglevel: warn
transport-loglevel: warn

# Retry logic — cloudflared auto-reconnects on failure
retries: 5
grace-period: 30s

ingress:
  # ---- Authentication portal ----------------------------
  - hostname: auth.YOUR_DOMAIN
    service: http://authentik-server:9000
    originRequest:
      connectTimeout: 30s
      noTLSVerify: false
      # These headers tell Authentik the real client IP
      httpHostHeader: auth.YOUR_DOMAIN

  # ---- Guacamole (browser-based remote access) ----------
  - hostname: access.YOUR_DOMAIN
    service: http://guacamole:8080
    originRequest:
      connectTimeout: 30s
      noTLSVerify: false
      # WebSocket support required for Guacamole's protocol
      http2Origin: false

  # ---- Grafana monitoring (restricted via CF Access) ----
  - hostname: monitor.YOUR_DOMAIN
    service: http://grafana:3000
    originRequest:
      connectTimeout: 30s
      noTLSVerify: false

  # ---- Catch-all: deny everything else ------------------
  # Any hostname not listed above returns 404 — never proxied.
  - service: http_status:404
