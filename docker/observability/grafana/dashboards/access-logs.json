      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"authentik-server\"} |= \"mfa_failed\" [$__range]))",
          "legendFormat": "MFA Failures",
          "refId": "A"
        }
      ],
      "title": "MFA Failures",
      "type": "stat"
