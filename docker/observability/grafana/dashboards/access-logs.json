      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"guacamole\"} |= \"GUAC_STATUS_SUCCESS\" [$__range]))",
          "legendFormat": "Remote Sessions",
          "refId": "A"
        }
      ],
      "title": "Remote Sessions",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
